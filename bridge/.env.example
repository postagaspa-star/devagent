# ── DevAgent Bridge configuration ────────────────────────────────────────
# Copy this file to .env and fill in the values.

# URL of your DevAgent server on Render (wss:// or https:// both work)
SERVER_URL=wss://devagent-xxxx.onrender.com

# Shared secret — must match the BRIDGE_SECRET env var set on Render
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRIDGE_SECRET=your-secret-here

# The local folder the agent is allowed to read/write.
# All relative paths from the agent are resolved against this root.
# Default: the directory from which you run the bridge
WORKSPACE_ROOT=C:\Users\YourName\Desktop
